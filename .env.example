# Copy to .env.local for local development. All variables are optional locally.

# Email delivery (contact form). Without this, submissions are logged to console.
RESEND_API_KEY=

# Where contact form submissions are sent. Falls back to Resend's test inbox.
CONTACT_TO_EMAIL=

# Verified sender. Falls back to "Pragma <onboarding@resend.dev>".
CONTACT_FROM_EMAIL=

# Canonical origin for hreflang, sitemap, OG URLs and JSON-LD (no trailing slash).
NEXT_PUBLIC_SITE_URL=
